{
  "name": "labtime-web-id",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "pnpm run build && wrangler dev --config .output/wrangler.toml",
    "postinstall": "nuxt prepare",
    "deploy": "pnpm run build && wrangler deploy --config .output/wrangler.toml",
    "cf-typegen": "wrangler types",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-vue-next": "^0.576.0",
    "nuxt": "^4.3.1",
    "radix-vue": "^1.9.17",
    "reka-ui": "^2.8.2",
    "shadcn-nuxt": "2.4.3",
    "tailwind-merge": "^3.5.0",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.2",
    "@nuxtjs/tailwindcss": "7.0.0-beta.1",
    "@types/node": "^25.3.3",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vueuse/core": "^14.2.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "h3": "2.0.1-rc.14",
    "nitro-cloudflare-dev": "^0.2.2",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.69.0"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3"
    }
  }
}